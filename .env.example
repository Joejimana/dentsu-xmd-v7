# Copie ce fichier en .env et remplis les valeurs

# Token GitHub avec permissions "repo" — pour sauvegarder les sessions
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx

# Propriétaire et nom du repo GitHub (identiques à ceux configurés sur Render)
GITHUB_OWNER=natsu242
GITHUB_REPO=dentsu-xmd-v7

# Port du serveur (Render le définit automatiquement à 10000)
PORT=10000
